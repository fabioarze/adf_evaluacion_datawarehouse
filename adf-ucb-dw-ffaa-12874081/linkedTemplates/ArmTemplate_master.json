{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Nombre de instancia de Data Factory",
			"defaultValue": "adf-ucb-dw-ffaa-12874081"
		},
		"ls_dw_fuerzas_armadas_destino_password": {
			"type": "secureString",
			"metadata": "Cadena protegida para \"password\"de \"ls_dw_fuerzas_armadas_destino\""
		},
		"ls_oltp_fuerzas_armadas_origen_password": {
			"type": "secureString",
			"metadata": "Cadena protegida para \"password\"de \"ls_oltp_fuerzas_armadas_origen\""
		},
		"ls_dw_fuerzas_armadas_destino_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sql-ucb-sisger-ffaa-12874081.database.windows.net"
		},
		"ls_dw_fuerzas_armadas_destino_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "dw_fuerzas_armadas"
		},
		"ls_dw_fuerzas_armadas_destino_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "fabio"
		},
		"ls_oltp_fuerzas_armadas_origen_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "server02-fuerzas-armadas-bolivia.database.windows.net"
		},
		"ls_oltp_fuerzas_armadas_origen_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "erp-fuerzas-armadas-bolivia-2"
		},
		"ls_oltp_fuerzas_armadas_origen_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "userSisGer"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI de la cuenta de almacenamiento que contiene las plantillas de ARM vinculadas."
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Token de SAS para la cuenta de almacenamiento que contiene las plantillas de ARM vinculadas"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-ucb-dw-ffaa-12874081_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_dw_fuerzas_armadas_destino_password": {
						"value": "[parameters('ls_dw_fuerzas_armadas_destino_password')]"
					},
					"ls_oltp_fuerzas_armadas_origen_password": {
						"value": "[parameters('ls_oltp_fuerzas_armadas_origen_password')]"
					},
					"ls_dw_fuerzas_armadas_destino_properties_typeProperties_server": {
						"value": "[parameters('ls_dw_fuerzas_armadas_destino_properties_typeProperties_server')]"
					},
					"ls_dw_fuerzas_armadas_destino_properties_typeProperties_database": {
						"value": "[parameters('ls_dw_fuerzas_armadas_destino_properties_typeProperties_database')]"
					},
					"ls_dw_fuerzas_armadas_destino_properties_typeProperties_userName": {
						"value": "[parameters('ls_dw_fuerzas_armadas_destino_properties_typeProperties_userName')]"
					},
					"ls_oltp_fuerzas_armadas_origen_properties_typeProperties_server": {
						"value": "[parameters('ls_oltp_fuerzas_armadas_origen_properties_typeProperties_server')]"
					},
					"ls_oltp_fuerzas_armadas_origen_properties_typeProperties_database": {
						"value": "[parameters('ls_oltp_fuerzas_armadas_origen_properties_typeProperties_database')]"
					},
					"ls_oltp_fuerzas_armadas_origen_properties_typeProperties_userName": {
						"value": "[parameters('ls_oltp_fuerzas_armadas_origen_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "adf-ucb-dw-ffaa-12874081_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adf-ucb-dw-ffaa-12874081_ArmTemplate_0')]"
			]
		},
		{
			"name": "adf-ucb-dw-ffaa-12874081_ArmTemplate_2",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_2.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adf-ucb-dw-ffaa-12874081_ArmTemplate_1')]"
			]
		}
	]
}