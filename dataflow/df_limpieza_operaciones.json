{
	"name": "df_limpieza_operaciones",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_bronze_operaciones",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_silver_operaciones",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_operacion as integer,",
				"          id_tipo as integer,",
				"          id_unidad_resp as integer,",
				"          id_zona as integer,",
				"          nombre_operacion as string,",
				"          fecha_inicio as string,",
				"          fecha_fin as string,",
				"          efectivos_desplegados as string,",
				"          vehiculos_utilizados as string,",
				"          duracion_dias as string,",
				"          costo_operacion as string,",
				"          resultado as string,",
				"          detenidos as string,",
				"          area_km2 as string,",
				"          incidentes as string,",
				"          observaciones as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source1 derive(observaciones = initCap(observaciones),",
				"          fecha_inicio = case(\r",
				"    isNull(fecha_inicio) || length(trim(toString(fecha_inicio))) == 0 || fecha_inicio == 'NULL', 'Sin Dato',\r",
				"    toString(\r",
				"        coalesce(\r",
				"            /* PARCHES EXCLUSIVOS PARA LAS ÚLTIMAS CAPTURAS REBELDES (aqo, ene) */\r",
				"            toTimestamp(replace(replace(lower(trim(fecha_inicio)), 'aqo', '08'), '-', ' '), 'dd MM yyyy'),\r",
				"            toTimestamp(replace(replace(lower(trim(fecha_inicio)), 'ene', '01'), '-', ' '), 'dd MM yyyy'),\r",
				"            toTimestamp(replace(replace(lower(trim(fecha_inicio)), 'ene', '01'), '/', ' '), 'dd MM yyyy'),\r",
				"            \r",
				"            /* TRADUCCIÓN DE MESES COMPLETOS ELIMINANDO DOBLES ESPACIOS FANTASMAS */\r",
				"            toTimestamp(\r",
				"                replace(replace(replace(regexReplace(lower(trim(fecha_inicio)), '\\\\s+', ' '), 'abril', '04'), 'febrero', '02'), 'octubre', '10'), \r",
				"                'MM dd, yyyy'\r",
				"            ),\r",
				"            \r",
				"            /* FORMATOS ANTERIORES QUE YA TE FUNCIONABAN BIEN */\r",
				"            toTimestamp(fecha_inicio, 'dd-MMM-yyyy'),\r",
				"            toTimestamp(lower(fecha_inicio), 'dd-mmm-yyyy'),\r",
				"            toTimestamp(fecha_inicio, 'dd/MMM/yyyy'),\r",
				"            toTimestamp(lower(fecha_inicio), 'dd/mmm/yyyy'),\r",
				"            toTimestamp(trim(fecha_inicio), 'yyyy/MM/dd'),\r",
				"            toTimestamp(trim(fecha_inicio), 'yyyy-MM-dd'),\r",
				"            toTimestamp(trim(fecha_inicio), 'dd/MM/yyyy'),\r",
				"            toTimestamp(trim(fecha_inicio), 'dd-MM-yyyy'),\r",
				"            toTimestamp(trim(fecha_inicio), 'yyyyMMdd'),\r",
				"            toTimestamp(trim(fecha_inicio), 'MM-dd-yyyy'),\r",
				"            toTimestamp(trim(fecha_inicio), 'MM/dd/yyyy')\r",
				"        ),\r",
				"        'dd-MM-yyyy'\r",
				"    )\r",
				"),",
				"          fecha_fin = case(\r",
				"    isNull(fecha_fin) || length(trim(toString(fecha_fin))) == 0 || fecha_fin == 'NULL', 'Sin Dato',\r",
				"    toString(\r",
				"        coalesce(\r",
				"            /* PARCHES EXCLUSIVOS PARA LAS ÚLTIMAS CAPTURAS REBELDES (aqo, ene) */\r",
				"            toTimestamp(replace(replace(lower(trim(fecha_fin)), 'aqo', '08'), '-', ' '), 'dd MM yyyy'),\r",
				"            toTimestamp(replace(replace(lower(trim(fecha_fin)), 'ene', '01'), '-', ' '), 'dd MM yyyy'),\r",
				"            toTimestamp(replace(replace(lower(trim(fecha_fin)), 'ene', '01'), '/', ' '), 'dd MM yyyy'),\r",
				"            \r",
				"            /* TRADUCCIÓN DE MESES COMPLETOS ELIMINANDO DOBLES ESPACIOS FANTASMAS */\r",
				"            toTimestamp(\r",
				"                replace(replace(replace(regexReplace(lower(trim(fecha_fin)), '\\\\s+', ' '), 'abril', '04'), 'febrero', '02'), 'octubre', '10'), \r",
				"                'MM dd, yyyy'\r",
				"            ),\r",
				"            \r",
				"            /* FORMATOS ANTERIORES QUE YA TE FUNCIONABAN BIEN */\r",
				"            toTimestamp(fecha_fin, 'dd-MMM-yyyy'),\r",
				"            toTimestamp(lower(fecha_fin), 'dd-mmm-yyyy'),\r",
				"            toTimestamp(fecha_fin, 'dd/MMM/yyyy'),\r",
				"            toTimestamp(lower(fecha_fin), 'dd/mmm/yyyy'),\r",
				"            toTimestamp(trim(fecha_fin), 'yyyy/MM/dd'),\r",
				"            toTimestamp(trim(fecha_fin), 'yyyy-MM-dd'),\r",
				"            toTimestamp(trim(fecha_fin), 'dd/MM/yyyy'),\r",
				"            toTimestamp(trim(fecha_fin), 'dd-MM-yyyy'),\r",
				"            toTimestamp(trim(fecha_fin), 'yyyyMMdd'),\r",
				"            toTimestamp(trim(fecha_fin), 'MM-dd-yyyy'),\r",
				"            toTimestamp(trim(fecha_fin), 'MM/dd/yyyy')\r",
				"        ),\r",
				"        'dd-MM-yyyy'\r",
				"    )\r",
				"),",
				"          efectivos_desplegados = iif(isNull(efectivos_desplegados) || trim(toString(efectivos_desplegados)) == '' || efectivos_desplegados == 'NULL',     toString(null()),     toString(regexReplace(trim(toString(efectivos_desplegados)), '[^0-9]', '')) + ' Efectivos' ),",
				"          vehiculos_utilizados = iif(isNull(vehiculos_utilizados) || trim(toString(vehiculos_utilizados)) == '' || vehiculos_utilizados == 'NULL',     toString(null()),     toString(regexReplace(trim(toString(vehiculos_utilizados)), '[^0-9]', '')) + ' Vehículos' ),",
				"          duracion_dias = iif(isNull(duracion_dias) || trim(toString(duracion_dias)) == '' || duracion_dias == 'NULL',     toString(null()),     toString(regexReplace(trim(toString(duracion_dias)), '[^0-9]', '')) + ' Días' ),",
				"          costo_operacion = iif(isNull(costo_operacion) || trim(toString(costo_operacion)) == '' || costo_operacion == 'NULL', \r",
				"    toString(null()),\r",
				"    \r",
				"    /* 1. DETECTOR DE MONEDA */\r",
				"    iif(rlike(upper(toString(costo_operacion)), '\\\\$|USD'), 'USD ', 'Bs. ') + \r",
				"    \r",
				"    /* 2. LIMPIEZA E INYECCIÓN DE COMAS EN LOS MILES */\r",
				"    regexReplace(\r",
				"        regexReplace(\r",
				"            iif(\r",
				"                /* ¿Termina en exactamente 2 centavos? */\r",
				"                rlike(regexReplace(toString(costo_operacion), '[^0-9\\\\.,]', ''), '[\\\\.,][0-9]{2}$'),\r",
				"                /* SI: Le recorta los centavos para limpiar solo los miles */\r",
				"                substring(regexReplace(toString(costo_operacion), '[^0-9\\\\.,]', ''), 1, length(regexReplace(toString(costo_operacion), '[^0-9\\\\.,]', '')) - 3),\r",
				"                /* NO: Toma todo el número completo */\r",
				"                regexReplace(toString(costo_operacion), '[^0-9\\\\.,]', '')\r",
				"            ), \r",
				"            /* Elimina cualquier coma o punto basura que quedara en los miles */\r",
				"            '[\\\\.,]', \r",
				"            ''\r",
				"        ),\r",
				"        /* Expresión Regular Maestra: Inyecta una coma cada 3 dígitos de derecha a izquierda */\r",
				"        '(\\\\d)(?=(\\\\d{3})+$)', \r",
				"        '$1,'\r",
				"    ) \r",
				"    \r",
				"    + '.' + \r",
				"    \r",
				"    /* 3. RECUPERAR O AÑADIR CENTAVOS (.00) */\r",
				"    iif(\r",
				"        rlike(regexReplace(toString(costo_operacion), '[^0-9\\\\.,]', ''), '[\\\\.,][0-9]{2}$'),\r",
				"        right(regexReplace(toString(costo_operacion), '[^0-9\\\\.,]', ''), 2),\r",
				"        '00'\r",
				"    )\r",
				"),",
				"          resultado = iif(isNull(resultado) || trim(toString(resultado)) == '' || upper(trim(toString(resultado))) == 'NULL',     'Sin Resultado Especificado',     initCap(trim(regexReplace(toString(resultado), '[\"\\']', ''))) ),",
				"          detenidos = iif(isNull(detenidos) || trim(toString(detenidos)) == '' || upper(trim(toString(detenidos))) == 'NULL',     '0 Detenidos',     iif(         rlike(toString(detenidos), '[0-9]'),         regexReplace(toString(detenidos), '[^0-9]', '') + ' Detenidos',         '0 Detenidos'     ) ),",
				"          area_km2 = iif(isNull(area_km2) || trim(toString(area_km2)) == '' || toString(area_km2) == 'NULL',     toString(null()),     toString(regexReplace(trim(toString(area_km2)), '[^0-9\\\\.,]', '')) + ' km²' ),",
				"          incidentes = iif(isNull(incidentes) || trim(toString(incidentes)) == '' || toString(incidentes) == 'NULL',     toString(null()),     toString(regexReplace(trim(toString(incidentes)), '[^0-9]', '')) + ' Incidentes' )) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}