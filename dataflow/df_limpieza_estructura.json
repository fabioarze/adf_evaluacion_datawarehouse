{
	"name": "df_limpieza_estructura",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_bronze_estructura_organizacional",
						"type": "DatasetReference"
					},
					"name": "Hijos"
				},
				{
					"dataset": {
						"referenceName": "ds_bronze_estructura_organizacional",
						"type": "DatasetReference"
					},
					"name": "Padres"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_silver_estructura",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "join1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_estructura as integer,",
				"          id_padre as integer,",
				"          nivel as string,",
				"          nombre as string,",
				"          sigla as string,",
				"          tipo as string,",
				"          cobertura_departamentos as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> Hijos",
				"source(output(",
				"          id_estructura as integer,",
				"          id_padre as integer,",
				"          nivel as string,",
				"          nombre as string,",
				"          sigla as string,",
				"          tipo as string,",
				"          cobertura_departamentos as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> Padres",
				"Hijos, Padres join(Hijos@id_padre == Padres@id_estructura,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1 select(mapColumn(",
				"          id_estructura = Hijos@id_estructura,",
				"          id_padre = Hijos@id_padre,",
				"          nivel = Hijos@nivel,",
				"          nombre = Hijos@nombre,",
				"          sigla = Hijos@sigla,",
				"          tipo = Hijos@tipo,",
				"          cobertura_departamentos = Hijos@cobertura_departamentos,",
				"          nombre_padre = Padres@nombre",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     recreate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}